# Zieladresse fuer eingehende Projektanfragen
CONTACT_EMAIL=hansolowentertainment@gmail.com

# Optionaler E-Mail-Versanddienst fuer /api/contact (z. B. Resend, Postmark, SMTP-Relay).
# Ohne gueltigen API-Key nutzt das Formular automatisch den mailto:-Fallback im Browser.
# CONTACT_EMAIL_PROVIDER_API_KEY=

# Basis-URL der Website, wird fuer Canonical-/Open-Graph-Tags und die sitemap.xml benoetigt
NEXT_PUBLIC_SITE_URL=https://www.hansolow-entertainment.de

# Instagram-Profil von Hansolow Entertainment (siehe config/site.ts -> INSTAGRAM_URL)
# Sobald bekannt, hier UND in config/site.ts eintragen.
NEXT_PUBLIC_INSTAGRAM_URL=
